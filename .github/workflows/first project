# TRACK_PROFILES above describe layout/corner character and don't change race to race. 
# These modifiers describe the SESSION (conditions on a given day) and are applied on top of a TRACK_PROFILES entry before the car score is calculated, then renormalized back to sum to 1.0.

WETNESS_MODIFIERS = {
    "dry":          {"Aerodynamics": 1.00, "MechanicalGrip": 1.00, "Stability": 1.00, "Engine": 1.00, "EnergyManagement": 1.00},
    "damp":         {"Aerodynamics": 0.90, "MechanicalGrip": 1.15, "Stability": 1.15, "Engine": 0.95, "EnergyManagement": 0.95},
    "intermediate": {"Aerodynamics": 0.80, "MechanicalGrip": 1.25, "Stability": 1.25, "Engine": 0.90, "EnergyManagement": 0.90},
    "wet":          {"Aerodynamics": 0.70, "MechanicalGrip": 1.40, "Stability": 1.35, "Engine": 0.80, "EnergyManagement": 0.85},
}

TIME_OF_DAY_MODIFIERS = {
    "day":      {"Stability": 1.00, "MechanicalGrip": 1.00},
    "twilight": {"Stability": 1.05, "MechanicalGrip": 1.02},
    "night":    {"Stability": 1.10, "MechanicalGrip": 1.05},
}


def _clamp(value, lo, hi):
    return min(hi, max(lo, value))


def track_temp_modifiers(track_temp_c: float) -> dict:
    """
    Continuous (not bucketed) since track temp varies session to session.
    Baseline ~30C is treated as neutral (modifier = 1.0). Hot tracks push
    grip/engine/energy modifiers down (degradation, cooling, thermal
    management); cold tracks push aero up slightly (denser air) but grip
    down (tires never reach their window).
    """
    delta = track_temp_c - 30  # positive = hotter than baseline
    return {
        "Aerodynamics": _clamp(1 - delta * 0.003, 0.85, 1.15),
        "MechanicalGrip": _clamp(1 - abs(delta) * 0.0035, 0.80, 1.05),
        "Engine": _clamp(1 - max(0, delta) * 0.002, 0.85, 1.00),
        "EnergyManagement": _clamp(1 - max(0, delta) * 0.0015, 0.85, 1.00),
    }


def apply_conditions(base_weights: dict, wetness: str, time_of_day: str, track_temp_c: float) -> dict:
    """
    Applies wetness, time-of-day, and track-temperature modifiers to a
    TRACK_PROFILES entry, then renormalizes so the five attribute weights
    sum back to 1.0 (modifiers alone would push the total away from 1.0).
    """
    wet = WETNESS_MODIFIERS[wetness]
    tod = TIME_OF_DAY_MODIFIERS[time_of_day]
    temp = track_temp_modifiers(track_temp_c)

    adjusted = {}
    for key, value in base_weights.items():
        value *= wet.get(key, 1)
        value *= tod.get(key, 1)
        value *= temp.get(key, 1)
        adjusted[key] = value

    total = sum(adjusted.values())
    return {key: value / total for key, value in adjusted.items()}


# Driver score weighting: Pace dominates, Racecraft is secondary,
# Awareness is a smaller modifier (avoiding incidents/maximizing strategy reads).
# Experience is intentionally excluded from the raw driver score and instead used as a "consistency" modifier later in the OPI calculation, since a rookie and a
DRIVER_WEIGHTS = {"Pace": 0.60, "Racecraft": 0.30, "Awareness": 0.10}

# Final blend between car and driver contribution to the OPI.
CAR_WEIGHT_IN_FINAL = 0.55
DRIVER_WEIGHT_IN_FINAL = 0.45

# 3. THE PREDICTION ALGORITHM
def calculate_driver_score(driver_row: dict) -> float:
    """
    Weighted driver score: 60% Pace, 30% Racecraft, 10% Awareness.
    Experience is intentionally excluded here -- it's used later as a
    *consistency* (variance) modifier rather than a raw performance input,
    since a rookie and a veteran can both be fast, but the veteran is more
    likely to repeat that pace under pressure.
    """
    return (
        driver_row["Pace"] * DRIVER_WEIGHTS["Pace"]
        + driver_row["Racecraft"] * DRIVER_WEIGHTS["Racecraft"]
        + driver_row["Awareness"] * DRIVER_WEIGHTS["Awareness"]
    )


def calculate_car_score(
    constructor_row: dict,
    track_profile: str,
    wetness: str = "dry",
    time_of_day: str = "day",
    track_temp_c: float = 30.0,
) -> float:
    """
    Track-adjusted car score. Each track profile re-weights all five car attributes.
    Engine and Energy Management have constant weights (20% and 25%) across all tracks
    under baseline dry conditions. Aerodynamics, Mechanical Grip, and Stability vary
    by track to reflect circuit characteristics, since a car that's a great qualifying
    machine on a low-drag circuit (Monza) might be a handful through Monaco's hairpins.

    wetness / time_of_day / track_temp_c further adjust those weights for the session
    via apply_conditions() -- e.g. a wet, cool, night race shifts weight away from
    Aerodynamics and toward MechanicalGrip and Stability relative to the track's dry
    baseline profile.
    """
    base_weights = TRACK_PROFILES[track_profile]
    weights = apply_conditions(base_weights, wetness, time_of_day, track_temp_c)
    return (
        constructor_row["Aerodynamics"] * weights["Aerodynamics"]
        + constructor_row["MechanicalGrip"] * weights["MechanicalGrip"]
        + constructor_row["Stability"] * weights["Stability"]
        + constructor_row["Engine"] * weights["Engine"]
        + constructor_row["EnergyManagement"] * weights["EnergyManagement"]
    )


def calculate_opi(
    driver_row: dict,
    constructor_row: dict,
    track_profile: str,
    wetness: str = "dry",
    time_of_day: str = "day",
    track_temp_c: float = 30.0,
) -> dict:
    """
    Combines the track-adjusted car score (55%) and the driver score (45%)
    into a single Overall Performance Index (0-100), then derives a
    predicted grid range using Experience + Engine as a "variance"
    modifier: more experienced drivers in more reliable cars get a tighter
    (more confident) predicted range, while rookies in fragile cars get a
    wider band of uncertainty.

    wetness / time_of_day / track_temp_c are passed through to
    calculate_car_score to layer session conditions on top of the track's
    static profile.

    Returns a dict with the OPI, the sub-scores, and the predicted ranges.
    """
    driver_score = calculate_driver_score(driver_row)
    car_score = calculate_car_score(constructor_row, track_profile, wetness, time_of_day, track_temp_c)

    final_index = (car_score * CAR_WEIGHT_IN_FINAL) + (driver_score * DRIVER_WEIGHT_IN_FINAL)
    final_index = float(np.clip(final_index, 0, 100))

    # --- Variance modifier ---------------------------------------------
    # Average the driver's Experience and the car's Engine into a single "consistency" score. High consistency (close to 99) shrinks the +/- grid-position uncertainty band; low consistency widens it.
    consistency = (driver_row["Experience"] + constructor_row["Engine"]) / 2.0

    # Map consistency (60-99) to a position-range spread (roughly 1-4 places). This is a simple linear inverse mapping: higher consistency -> smaller spread. consistency=99 -> spread ~1, consistency=60 -> spread ~4
    spread = np.interp(consistency, [60, 99], [4, 1])
    spread = int(round(spread))
    spread = max(1, spread)

    # --- Convert OPI into an estimated grid slot -------------------------
    # Simple, transparent mapping: a higher OPI implies a smaller (better) grid number. We anchor OPI=100 -> P1 and degrade roughly 1 grid slot per ~3.2 OPI points lost, capped at P22 (a full F1 grid).
    base_position = (100 - final_index) / 3.2 + 1
    base_position = float(np.clip(base_position, 1, 22))

    qual_low = max(1, int(round(base_position - spread)))
    qual_high = min(22, int(round(base_position + spread)))

    # Race finish tends to carry slightly more variance than qualifying because of races incidents, strategy, and tire wear -- so we widen the race-day band a little relative to the qualifying band.
    race_spread = spread + 1
    race_low = max(1, int(round(base_position - race_spread)))
    race_high = min(22, int(round(base_position + race_spread)))

    return {
        "driver_score": round(driver_score, 1),
        "car_score": round(car_score, 1),
        "final_index": round(final_index, 1),
        "consistency": round(consistency, 1),
        "spread": spread,
        "qual_range": (qual_low, qual_high),
        "race_range": (race_low, race_high),
    }


def simulate_baseline_rivals(
    track_profile: str,
    wetness: str = "dry",
    time_of_day: str = "day",
    track_temp_c: float = 30.0,
    n: int = 4,
    seed: int = 42,
) -> pd.DataFrame:
    """
    Generates `n` simulated baseline driver/car combos for comparison bars.
    These represent a spread of midfield-to-front-running rivals so the
    user's customized pairing has something concrete to be benchmarked
    against. A fixed seed keeps the comparison set stable across reruns
    unless the user changes inputs that affect it. Rivals are scored under
    the same session conditions as the user's pairing so the benchmark
    stays fair -- a wet race shouldn't compare a wet-scored custom car
    against dry-scored rivals.
    """
    rng = np.random.default_rng(seed)
    rivals = []
    names = ["Rival A", "Rival B", "Rival C", "Rival D"][:n]
    for name in names:
        driver_row = {
            "Pace": rng.integers(78, 97),
            "Racecraft": rng.integers(75, 95),
            "Awareness": rng.integers(75, 95),
            "Experience": rng.integers(60, 99),
        }
        constructor_row = {
            "Aerodynamics": rng.integers(78, 96),
            "MechanicalGrip": rng.integers(78, 96),
            "Stability": rng.integers(78, 96),
            "Engine": rng.integers(70, 97),
            "EnergyManagement": rng.integers(75, 90),
        }
        result = calculate_opi(driver_row, constructor_row, track_profile, wetness, time_of_day, track_temp_c)
        rivals.append({"Name": name, "OPI": result["final_index"]})
    return pd.DataFrame(rivals)


# 4. PLOTLY VISUAL COMPONENTS
def make_gauge_chart(opi_value: float) -> go.Figure:
    """Gauge chart for the final OPI score, color-banded for quick read."""
    fig = go.Figure(
        go.Indicator(
            mode="gauge+number",
            value=opi_value,
            number={"suffix": " / 100", "font": {"size": 40}},
            title={"text": "Overall Performance Index", "font": {"size": 18}},
            gauge={
                "axis": {"range": [0, 100], "tickwidth": 1},
                "bar": {"color": "#E10600"},  # F1-red needle
                "steps": [
                    {"range": [0, 50], "color": "#3a3a3a"},
                    {"range": [50, 75], "color": "#6e6e6e"},
                    {"range": [75, 100], "color": "#c9c9c9"},
                ],
                "threshold": {
                    "line": {"color": "white", "width": 4},
                    "thickness": 0.75,
                    "value": opi_value,
                },
            },
        )
    )
    fig.update_layout(height=320, margin=dict(l=20, r=20, t=60, b=10))
    return fig


def make_radar_chart(driver_row: dict, constructor_row: dict, driver_name: str, team_name: str) -> go.Figure:
    """
    Radar/spider chart comparing the driver's skill balance (Pace,
    Racecraft, Awareness, Experience) against the constructor's capability
    balance (Aero, Grip, Stability, Engine) on a shared 0-100 axis.
    """
    categories = ["Attribute 1", "Attribute 2", "Attribute 3", "Attribute 4"]
    driver_labels = ["Pace", "Racecraft", "Awareness", "Experience"]
    car_labels = ["Aerodynamics", "MechanicalGrip", "Stability", "Engine", "EnergyManagement"]

    driver_values = [driver_row[k] for k in driver_labels]
    car_values = [constructor_row[k] for k in car_labels]

    # Close the loop for both traces by repeating the first value.
    driver_values_closed = driver_values + [driver_values[0]]
    car_values_closed = car_values + [car_values[0]]
    theta_driver = driver_labels + [driver_labels[0]]
    theta_car = car_labels + [car_labels[0]]

    fig = go.Figure()
    fig.add_trace(
        go.Scatterpolar(
            r=driver_values_closed,
            theta=theta_driver,
            fill="toself",
            name=f"Driver: {driver_name}",
            line_color="#E10600",
        )
    )
    fig.add_trace(
        go.Scatterpolar(
            r=car_values_closed,
            theta=theta_car,
            fill="toself",
            name=f"Constructor: {team_name}",
            line_color="#1E88E5",
        )
    )
    fig.update_layout(
        polar=dict(radialaxis=dict(visible=True, range=[0, 100])),
        showlegend=True,
        height=420,
        margin=dict(l=40, r=40, t=40, b=40),
    )
    return fig


def make_comparison_bar_chart(custom_name: str, custom_opi: float, rivals_df: pd.DataFrame) -> go.Figure:
    """Bar chart benchmarking the user's custom pairing against simulated rivals."""
    names = [custom_name] + rivals_df["Name"].tolist()
    values = [custom_opi] + rivals_df["OPI"].tolist()
    colors = ["#E10600"] + ["#6e6e6e"] * len(rivals_df)

    # Sort descending so the chart reads like a leaderboard.
    order = np.argsort(values)[::-1]
    names = [names[i] for i in order]
    values = [values[i] for i in order]
    colors = [colors[i] for i in order]

    fig = go.Figure(
        go.Bar(
            x=names,
            y=values,
            marker_color=colors,
            text=[f"{v:.1f}" for v in values],
            textposition="outside",
        )
    )
    fig.update_layout(
        yaxis=dict(title="OPI", range=[0, 105]),
        xaxis=dict(title=""),
        height=380,
        margin=dict(l=20, r=20, t=30, b=20),
    )
    return fig

