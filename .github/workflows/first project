    driver_row = {
        "Pace": pace,
        "Racecraft": racecraft,
        "Awareness": awareness,
        "Experience": experience,
    }
    constructor_row = {
        "Aerodynamics": aero,
        "MechanicalGrip": grip,
        "Stability": stability,
        "Engine": reliability,
        "EnergyManagement": energy_management,
    }

    result = calculate_opi(driver_row, constructor_row, track_profile, wetness, time_of_day, track_temp_c)

    # -------------------------------------------------------------
    # MAIN VIEW
    # -------------------------------------------------------------
    top_left, top_right = st.columns([1, 1.3])

    with top_left:
        st.plotly_chart(make_gauge_chart(result["final_index"]), use_container_width=True)

    with top_right:
        st.subheader("Predicted Outcome")
        c1, c2 = st.columns(2)
        with c1:
            st.metric(
                "Predicted Qualifying Position",
                f"P{result['qual_range'][0]}–P{result['qual_range'][1]}",
            )
        with c2:
            st.metric(
                "Predicted Race Finish",
                f"P{result['race_range'][0]}–P{result['race_range'][1]}",
            )

        st.markdown(
            f"""
            **Breakdown for {driver_name} / {constructor_name} at {track_profile}**
            **({wetness}, {time_of_day}, {track_temp_c}°C):**
            - Driver Score (Pace/Racecraft/Awareness weighted): **{result['driver_score']}**
            - Track-Adjusted Car Score: **{result['car_score']}**
            - Consistency factor (Experience + Engine avg): **{result['consistency']}**
              → drives a ±{result['spread']} grid-position confidence band
            - **Final OPI: {result['final_index']} / 100**
            """
        )

    st.divider()

    mid_left, mid_right = st.columns(2)

    with mid_left:
        st.subheader("Skill Balance: Driver vs. Constructor")
        st.plotly_chart(
            make_radar_chart(driver_row, constructor_row, driver_name, constructor_name),
            use_container_width=True,
        )

    with mid_right:
        st.subheader(f"Benchmark vs. Simulated Rivals — {track_profile} ({wetness}, {time_of_day})")
        rivals_df = simulate_baseline_rivals(track_profile, wetness, time_of_day, track_temp_c)
        custom_label = f"{driver_name.split()[-1]} / {constructor_name}"
        st.plotly_chart(
            make_comparison_bar_chart(custom_label, result["final_index"], rivals_df),
            use_container_width=True,
        )
        st.caption(
            "Rival drivers/cars are randomly simulated within realistic "
            "ranges for benchmarking purposes, not real competitors."
        )


if __name__ == "__main__":
    main()
